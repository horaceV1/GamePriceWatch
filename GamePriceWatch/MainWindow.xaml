<ui:FluentWindow x:Class="GamePriceWatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:GamePriceWatch.ViewModels"
        xmlns:converters="clr-namespace:GamePriceWatch.Converters"
        Title="Game Price Watch"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.DataContext>
        <vm:MainViewModel />
    </ui:FluentWindow.DataContext>

    <ui:FluentWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="Game Price Watch" ShowMaximize="True" ShowMinimize="True" />

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="&#x1F3AE; Game Price Watch" FontSize="28" FontWeight="Bold" />
                    <TextBlock FontSize="13" Opacity="0.6" Margin="0,2,0,0">
                        <Run Text="Tracking the latest 20 game releases from AllKeyShop &#x2022; Last updated: " />
                        <Run Text="{Binding LastUpdated}" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="Refresh Now"
                               Icon="{ui:SymbolIcon ArrowSync24}"
                               Command="{Binding LoadGamesCommand}"
                               Appearance="Primary"
                               Margin="0,0,0,0"
                               Padding="16,10" FontSize="13" />
                </StackPanel>
            </Grid>

            <!-- Progress Bar (visible when loading) -->
            <Grid Grid.Row="1" Margin="0,0,0,8"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                                 Height="4" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7" />
                </StackPanel>
            </Grid>

            <!-- Games List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,0,10"
                                    Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Game Header -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Border Background="#2980B9" CornerRadius="4" Padding="8,3"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Platform}" Foreground="White"
                                                               FontSize="11" FontWeight="Medium" />
                                                </Border>
                                                <Border Background="#7F8C8D" CornerRadius="4" Padding="8,3"
                                                        Margin="0,0,8,0"
                                                        Visibility="{Binding ReleaseDate, Converter={StaticResource NullToVisibility}}">
                                                    <TextBlock Text="{Binding ReleaseDate}" Foreground="White"
                                                               FontSize="11" />
                                                </Border>
                                                <Border Background="#27AE60" CornerRadius="4" Padding="8,3"
                                                        Visibility="{Binding HistoricalLow, Converter={StaticResource NullToVisibility}}">
                                                    <TextBlock Foreground="White" FontSize="11">
                                                        <Run Text="Historical Low: " />
                                                        <Run Text="{Binding HistoricalLow, Mode=OneWay}" />
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <ui:HyperlinkButton Grid.Column="1"
                                                            NavigateUri="{Binding PageUrl}"
                                                            Content="View on AllKeyShop"
                                                            VerticalAlignment="Top"
                                                            FontSize="12" />
                                    </Grid>

                                    <!-- Store Prices Table -->
                                    <Border Grid.Row="1" Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="6" Padding="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Table Header -->
                                            <Grid Grid.Row="0" Margin="12,8,12,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="100" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold"
                                                           FontSize="12" Opacity="0.5" />
                                                <TextBlock Grid.Column="1" Text="STORE" FontWeight="SemiBold"
                                                           FontSize="12" Opacity="0.5" />
                                                <TextBlock Grid.Column="2" Text="REGION" FontWeight="SemiBold"
                                                           FontSize="12" Opacity="0.5" />
                                                <TextBlock Grid.Column="3" Text="EDITION" FontWeight="SemiBold"
                                                           FontSize="12" Opacity="0.5" />
                                                <TextBlock Grid.Column="4" Text="PRICE" FontWeight="SemiBold"
                                                           FontSize="12" Opacity="0.5"
                                                           HorizontalAlignment="Right" />
                                            </Grid>

                                            <!-- Price Rows -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding StorePrices}"
                                                          Margin="0,0,0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12,8" Margin="4,1,4,0"
                                                                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                                                CornerRadius="4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="40" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="100" />
                                                                    <ColumnDefinition Width="120" />
                                                                    <ColumnDefinition Width="100" />
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Store Name -->
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding StoreName}"
                                                                               FontWeight="Medium" FontSize="13" />
                                                                    <TextBlock Text="{Binding StoreRating}"
                                                                               FontSize="10" Opacity="0.5"
                                                                               Visibility="{Binding StoreRating, Converter={StaticResource NullToVisibility}}" />
                                                                </StackPanel>

                                                                <!-- Region -->
                                                                <TextBlock Grid.Column="2" Text="{Binding Region}"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12" Opacity="0.7" />

                                                                <!-- Edition -->
                                                                <TextBlock Grid.Column="3" Text="{Binding Edition}"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12" Opacity="0.7" />

                                                                <!-- Price -->
                                                                <TextBlock Grid.Column="4" Text="{Binding Price}"
                                                                           VerticalAlignment="Center"
                                                                           HorizontalAlignment="Right"
                                                                           FontSize="15" FontWeight="Bold"
                                                                           Foreground="#2ECC71" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- No prices message -->
                                            <TextBlock Grid.Row="1"
                                                       Text="No store prices available for this game."
                                                       FontSize="12" Opacity="0.5"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,12,0,12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StorePrices.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Games.Count}" Value="0" />
                                    <Condition Binding="{Binding IsLoading}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="&#x1F3AE;" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,12" />
                <TextBlock Text="No games loaded yet" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Click 'Refresh Now' to fetch the latest prices from AllKeyShop"
                           FontSize="13" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,16" />
                <ui:Button Content="Load Games"
                           Icon="{ui:SymbolIcon Play24}"
                           Appearance="Primary"
                           Command="{Binding LoadGamesCommand}"
                           HorizontalAlignment="Center"
                           Padding="24,12" FontSize="14" />
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12"
                           VerticalAlignment="Center" Opacity="0.7" />
                <TextBlock Grid.Column="1" FontSize="12" VerticalAlignment="Center" Opacity="0.5"
                           Text="Auto-refresh: Every 1 hour &#x2022; Source: allkeyshop.com" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
